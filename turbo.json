{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "LIVEAVATAR_API_KEY",
    "LIVEAVATAR_API_URL",
    "LIVEAVATAR_AVATAR_ID",
    "LIVEAVATAR_VOICE_ID",
    "LIVEAVATAR_CONTEXT_ID",
    "LIVEAVATAR_LANGUAGE",
    "LIVEAVATAR_CREDITS_PER_MINUTE",
    "LIVEAVATAR_DAILY_CREDIT_LIMIT",
    "ELEVENLABS_API_KEY",
    "ELEVENLABS_VOICE_ID",
    "OPENAI_API_KEY",
    "GROKAI_API_KEY",
    "LLM_PROVIDER",
    "RATE_LIMIT_PER_MINUTE",
    "RATE_LIMIT_PER_DAY",
    "SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "VERCEL_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "lib/**",
        "dist/**"
      ],
      "env": [
        "LIVEAVATAR_API_KEY",
        "LIVEAVATAR_API_URL",
        "LIVEAVATAR_AVATAR_ID",
        "LIVEAVATAR_VOICE_ID",
        "LIVEAVATAR_CONTEXT_ID",
        "LIVEAVATAR_LANGUAGE",
        "LIVEAVATAR_CREDITS_PER_MINUTE",
        "LIVEAVATAR_DAILY_CREDIT_LIMIT",
        "ELEVENLABS_API_KEY",
        "ELEVENLABS_VOICE_ID",
        "OPENAI_API_KEY",
        "GROKAI_API_KEY",
        "LLM_PROVIDER",
        "RATE_LIMIT_PER_MINUTE",
        "RATE_LIMIT_PER_DAY",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "VERCEL_ENV"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "LIVEAVATAR_API_KEY",
        "LIVEAVATAR_API_URL",
        "LIVEAVATAR_AVATAR_ID",
        "LIVEAVATAR_VOICE_ID",
        "LIVEAVATAR_CONTEXT_ID",
        "LIVEAVATAR_LANGUAGE",
        "LIVEAVATAR_CREDITS_PER_MINUTE",
        "LIVEAVATAR_DAILY_CREDIT_LIMIT",
        "ELEVENLABS_API_KEY",
        "ELEVENLABS_VOICE_ID",
        "OPENAI_API_KEY",
        "GROKAI_API_KEY",
        "LLM_PROVIDER",
        "RATE_LIMIT_PER_MINUTE",
        "RATE_LIMIT_PER_DAY",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "VERCEL_ENV"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "env": [
        "LIVEAVATAR_API_KEY",
        "LIVEAVATAR_API_URL",
        "LIVEAVATAR_AVATAR_ID",
        "LIVEAVATAR_VOICE_ID",
        "LIVEAVATAR_CONTEXT_ID",
        "LIVEAVATAR_LANGUAGE",
        "LIVEAVATAR_CREDITS_PER_MINUTE",
        "LIVEAVATAR_DAILY_CREDIT_LIMIT",
        "ELEVENLABS_API_KEY",
        "ELEVENLABS_VOICE_ID",
        "OPENAI_API_KEY",
        "GROKAI_API_KEY",
        "LLM_PROVIDER",
        "RATE_LIMIT_PER_MINUTE",
        "RATE_LIMIT_PER_DAY",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "VERCEL_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "LIVEAVATAR_API_KEY",
        "LIVEAVATAR_API_URL",
        "LIVEAVATAR_AVATAR_ID",
        "LIVEAVATAR_VOICE_ID",
        "LIVEAVATAR_CONTEXT_ID",
        "LIVEAVATAR_LANGUAGE",
        "LIVEAVATAR_CREDITS_PER_MINUTE",
        "LIVEAVATAR_DAILY_CREDIT_LIMIT",
        "ELEVENLABS_API_KEY",
        "ELEVENLABS_VOICE_ID",
        "OPENAI_API_KEY",
        "GROKAI_API_KEY",
        "LLM_PROVIDER",
        "RATE_LIMIT_PER_MINUTE",
        "RATE_LIMIT_PER_DAY",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "VERCEL_ENV"
      ]
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
